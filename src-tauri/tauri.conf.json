{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warfare",
  "version": "2.0.0",
  "identifier": "com.opfour.warfare",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "python3 -m http.server 8000",
    "beforeBuildCommand": "",
    "beforeBundleCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Warfare 2.0",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon_square.png"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Game",
    "shortDescription": "Warfare 2.0 - Hex Strategy Game",
    "longDescription": "Warfare 2.0 is a hex-based strategy game, a remake of the 1995 classic by Carric Moor Games."
  }
}